{
  "name": "strait",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "turbo run dev",
    "storybook": "turbo run storybook",
    "build-storybook": "turbo run build-storybook",
    "chromatic": "turbo run build-storybook && bun run --filter @strait/storybook chromatic",
    "build": "turbo run build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:conventions": "bun scripts/check-conventions.mjs",
    "check:heavy": "bun scripts/check-heavy-deps.mjs",
    "check:docs": "bun scripts/check-docs.mjs",
    "check:docs:drift": "bun scripts/generate-llms.ts --check",
    "docs:generate": "bun scripts/generate-llms.ts",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:stories": "bun run --filter @strait/storybook test-storybook",
    "changeset": "changeset",
    "version-packages": "changeset version && bun install",
    "release": "changeset publish",
    "verify": "biome check . && bun scripts/check-conventions.mjs && bun scripts/check-heavy-deps.mjs && bun scripts/check-docs.mjs && bun scripts/generate-llms.ts --check && turbo run build && turbo run typecheck && turbo run test && turbo run build-storybook",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@changesets/cli": "^2.31.0",
    "http-server": "^14.1.1",
    "ts-morph": "^28.0.0",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "ultracite": "^7.7.0",
    "wait-on": "^9.0.10"
  }
}
