{
  "name": "strait",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.14",
  "scripts": {
    "prepare": "lefthook install",
    "dev": "turbo run dev",
    "docs:dev": "turbo run dev --filter=@strait/docs",
    "docs:build": "turbo run build --filter=@strait/docs",
    "storybook": "turbo run storybook",
    "build-storybook": "turbo run build-storybook",
    "chromatic": "turbo run build-storybook && bun run --filter @strait/storybook chromatic",
    "build": "turbo run build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:conventions": "bun scripts/check-conventions.mjs",
    "check:heavy": "bun scripts/check-heavy-deps.mjs",
    "check:trusted": "bun scripts/check-trusted-deps.mjs",
    "check:docs": "bun scripts/check-docs.mjs",
    "check:docs:drift": "bun scripts/generate-llms.ts --check",
    "check:docs:pages": "bun scripts/check-docs-pages.mjs",
    "check:changeset": "bun scripts/check-changeset-format.mjs",
    "test:release-notes": "node --test scripts/release-notes.test.mjs",
    "docs:generate": "bun scripts/generate-llms.ts && bun scripts/generate-tokens.ts && bun scripts/generate-changelog.ts && bun scripts/generate-demo-registry.ts",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:stories": "bun run --filter @strait/storybook test-storybook",
    "changeset": "changeset",
    "version-packages": "changeset version && bun install",
    "release": "changeset publish",
    "verify": "biome check . && bun scripts/check-conventions.mjs && bun scripts/check-heavy-deps.mjs && bun scripts/check-trusted-deps.mjs && bun scripts/check-docs.mjs && bun scripts/check-docs-pages.mjs && bun scripts/check-changeset-format.mjs && bun scripts/generate-llms.ts --check && bun scripts/generate-tokens.ts --check && bun scripts/generate-changelog.ts --check && node --test scripts/release-notes.test.mjs && turbo run build && turbo run typecheck && turbo run test && turbo run build-storybook",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "http-server": "^14.1.1",
    "lefthook": "^2.1.9",
    "playwright-core": "^1.60.0",
    "ts-morph": "^28.0.0",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "ultracite": "^7.8.1",
    "wait-on": "^9.0.10"
  }
}
